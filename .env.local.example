# Copy this file to .env.local for local dev. Never commit .env.local.
#
# For Minimise, source the live values from ~/.minimise/aios-supabase.env:
#   AIOS_SUPABASE_URL       → VITE_SUPABASE_URL
#   AIOS_SUPABASE_ANON_KEY  → VITE_SUPABASE_ANON_KEY
#
# For a client fork, point both vars at the client's own Supabase project.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
